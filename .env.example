PORT=3000

# CopeCart IPN secret (from vendor's CopeCart IPN settings)
COPECART_IPN_SECRET=your_copecart_ipn_secret_here

# Traffic Manager postback configuration
TM_POSTBACK_BASE_URL=https://postback.wasabizone.com/
TM_POSTBACK_KEY=your_tm_postback_key_here

# Which CopeCart IPN field contains the click ID
CLICK_ID_FIELD=metadata

# Which CopeCart IPN field to use for the payout amount
# Options: transaction_amount, earned_amount, transaction_earned_amount
AMOUNT_FIELD=transaction_amount

LOG_LEVEL=info
